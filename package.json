{
  "name": "blood-moon-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "nuxt dev apps/web",
    "build": "nuxt build apps/web",
    "generate": "nuxt generate apps/web",
    "preview": "nuxt preview apps/web/.output",
    "web:dev": "nuxt dev apps/web",
    "web:build": "nuxt build apps/web",
    "web:generate": "nuxt generate apps/web",
    "web:preview": "nuxt preview apps/web/.output",
    "api:check": "node apps/api/scripts/check-api-structure.mjs",
    "check": "npm run api:check && npm run web:build",
    "postinstall": "nuxt prepare apps/web"
  },
  "dependencies": {
    "@nuxt/ui": "^4.0.0",
    "@pinia/nuxt": "^0.9.0",
    "lucide-vue-next": "^0.468.0",
    "nuxt": "^4.4.8",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.114"
  }
}
